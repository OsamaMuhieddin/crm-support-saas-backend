@startuml
title System Use Case Diagram - Files and Attachments (Masar)

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontName Arial
skinparam rectangle {
  BackgroundColor #F8FAFC
  BorderColor #2D3748
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #2D3748
  ArrowColor #2D3748
}

actor "Workspace Member" as WorkspaceMember <<abstract>>
actor "Workspace Manager\n(Owner/Admin)" as WorkspaceManager <<abstract>>
actor "Agent" as Agent
actor "Viewer" as Viewer
actor "Customer /\nWidget Visitor" as WidgetVisitor

WorkspaceManager --|> WorkspaceMember
Agent --|> WorkspaceMember
Viewer --|> WorkspaceMember

rectangle "Masar - CRM Support SaaS" as System {
  (View/List Files) as UCListFiles
  (View File\nMetadata) as UCMetadata
  (Download File) as UCDownload
  (Stream File\nDownload) as UCStream

  (Upload File) as UCUpload
  (Delete File) as UCDelete
  (Soft-Delete File\nand Links) as UCSoftDelete

  (Use File as\nAttachment) as UCAttachment
  (Validate File Access\nand Readiness) as UCValidate
  (Manage File Links) as UCManageLinks
  (Link File to\nTicket Message) as UCLinkMessage
  (Link File to\nTicket) as UCLinkTicket

  (Upload Widget\nAttachment) as UCWidgetUpload
  (Attach Widget File\nto Message) as UCWidgetAttach
}

WorkspaceMember --> UCListFiles
WorkspaceMember --> UCMetadata
WorkspaceMember --> UCDownload

WorkspaceManager --> UCUpload
WorkspaceManager --> UCDelete
WorkspaceManager --> UCAttachment
WorkspaceManager --> UCManageLinks

Agent --> UCUpload
Agent --> UCAttachment
Agent --> UCLinkMessage
Agent --> UCLinkTicket

Viewer --> UCListFiles
Viewer --> UCMetadata
Viewer --> UCDownload

WidgetVisitor --> UCWidgetUpload
WidgetVisitor --> UCWidgetAttach

UCDownload ..> UCStream : <<include>>
UCDelete ..> UCSoftDelete : <<include>>
UCAttachment ..> UCValidate : <<include>>
UCAttachment ..> UCLinkMessage : <<include>>
UCLinkMessage ..> UCLinkTicket : <<include>>
UCWidgetUpload ..> UCUpload : <<include>>
UCWidgetAttach ..> UCValidate : <<include>>
UCWidgetAttach ..> UCLinkMessage : <<include>>

@enduml
