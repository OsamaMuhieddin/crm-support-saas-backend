NODE_ENV=production
PORT=5000
MONGO_URI=mongodb://mongo:27017/crm_support_saas
TRUST_PROXY=1

# Public API URL behind NGINX + HTTPS
APP_BASE_URL=https://api.dev.example.com

# Local frontend can call the cloud backend now; add a deployed frontend origin later.
FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.dev.example.com
REALTIME_CORS_ORIGIN=http://localhost:5173,https://app.dev.example.com

# Auth / JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=crm-support-saas-backend
JWT_AUDIENCE=crm-support-saas
AUTH_BCRYPT_ROUNDS=12

# OTP / invites
OTP_EXPIRES_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX_PER_WINDOW=5
INVITE_EXPIRES_DAYS=7

# Billing / Stripe
BILLING_ENABLED=true
BILLING_TRIAL_DAYS=14
BILLING_DEV_TEST_CATALOG_LIMITS=false
BILLING_PROVIDER=stripe
BILLING_CURRENCY=USD
BILLING_GRACE_DAYS=7
BILLING_CATALOG_VERSION=v1
STRIPE_SECRET_KEY=
# For Azure, this must be the Stripe Dashboard webhook signing secret
# for https://api.dev.example.com/api/billing/webhooks/stripe
# Do not use the local Stripe CLI whsec_... value here.
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/settings/billing
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_EXTRA_SEAT_MONTHLY=
STRIPE_PRICE_EXTRA_STORAGE_MONTHLY=

# Realtime / Redis / BullMQ
REALTIME_ENABLED=true
REALTIME_PATH=/socket.io
REALTIME_TRANSPORTS=websocket,polling
REALTIME_PING_INTERVAL_MS=25000
REALTIME_PING_TIMEOUT_MS=20000
REALTIME_PRESENCE_TTL_MS=45000
REALTIME_TYPING_TTL_MS=8000
REALTIME_SOFT_CLAIM_TTL_MS=45000
REALTIME_ACTION_THROTTLE_MS=75
REALTIME_DEBUG_LOGGING=false
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
# On a single VM, Redis can stay enabled for BullMQ while the Socket.IO Redis
# adapter remains off unless you specifically want to test that adapter path.
REALTIME_REDIS_ADAPTER_ENABLED=false

# Email provider
SMTP_HOST=smtp_provider
SMTP_PORT=465
SMTP_USER=smtp_user
SMTP_PASS=smtp_password
EMAIL_FROM=email_from_address

# Private MinIO inside the Docker network
# For this single-VM dev setup, the backend MinIO credentials should match the
# MinIO server root credentials so the app can authenticate to the private MinIO service.
STORAGE_PROVIDER=minio
S3_ENDPOINT=minio
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-root-password
S3_BUCKET=crm-support-files
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# File policy
MAX_FILE_SIZE_BYTES=10485760
FILES_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,text/plain,application/zip
FILES_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.txt,.zip
FILES_UPLOAD_RATE_LIMIT_ENABLED=true
FILES_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
FILES_UPLOAD_RATE_LIMIT_MAX=20
FILES_DOWNLOAD_RATE_LIMIT_ENABLED=true
FILES_DOWNLOAD_RATE_LIMIT_WINDOW_SECONDS=60
FILES_DOWNLOAD_RATE_LIMIT_MAX=120

# MinIO container credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-root-password
