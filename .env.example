NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/crm_support_saas
# TRUST_PROXY=1

# Auth / JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=crm-support-saas-backend
JWT_AUDIENCE=crm-support-saas
AUTH_BCRYPT_ROUNDS=12

# OTP
OTP_EXPIRES_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX_PER_WINDOW=5

# Workspace invites
INVITE_EXPIRES_DAYS=7
APP_BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:5173

# Email providers (choose one)
# SendGrid
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@example.com

# Nodemailer SMTP (dev fallback)
NODEMAILER_HOST=
NODEMAILER_PORT=587
NODEMAILER_USER=
NODEMAILER_PASS=

# Files / Storage (MinIO by default)
STORAGE_PROVIDER=minio
S3_ENDPOINT=127.0.0.1
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123987
S3_BUCKET=crm-somename
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Files policy
MAX_FILE_SIZE_BYTES=10485760
FILES_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,text/plain,application/zip
FILES_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.txt,.zip
FILES_UPLOAD_RATE_LIMIT_ENABLED=true
FILES_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
FILES_UPLOAD_RATE_LIMIT_MAX=20
FILES_DOWNLOAD_RATE_LIMIT_ENABLED=true
FILES_DOWNLOAD_RATE_LIMIT_WINDOW_SECONDS=60
FILES_DOWNLOAD_RATE_LIMIT_MAX=120

# Local adapter fallback (useful for tests)
STORAGE_LOCAL_ROOT=.tmp/local-storage

# MinIO local docker credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
